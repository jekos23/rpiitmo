// Программа для Arduino
// Читает значение с потенциометра и отправляет его через USB (Serial) на Raspberry Pi

const int potPin = A0; // Пин, к которому подключен потенциометр
int potValue = 0;      // Переменная для хранения значения

void setup() {
  // Инициализируем последовательный порт на скорости 9600 бод (бит/с)
  Serial.begin(9600);
}

void loop() {
  // Читаем аналоговое значение с пина A0 (от 0 до 1023)
  potValue = analogRead(potPin);
  
  // Отправляем значение в Serial монитор (и на Raspberry Pi)
  Serial.println(potValue);
  
  // Небольшая задержка, чтобы не спамить в порт слишком быстро
  // Отправляем данные 20 раз в секунду
  delay(50);
}
